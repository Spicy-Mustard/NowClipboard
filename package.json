{
  "name": "nowclipboard",
  "version": "1.1.8",
  "description": "现代剪贴板工具库 - 零依赖，支持浏览器和 Node.js 双环境",
  "main": "NowClipboard.js",
  "module": "NowClipboard.esm.mjs",
  "types": "NowClipboard.d.ts",
  "exports": {
    ".": {
      "types": "./NowClipboard.d.ts",
      "import": "./NowClipboard.esm.mjs",
      "require": "./NowClipboard.js"
    }
  },
  "files": [
    "NowClipboard.js",
    "NowClipboard.js.map",
    "NowClipboard.esm.mjs",
    "NowClipboard.esm.mjs.map",
    "NowClipboard.min.js",
    "NowClipboard.min.js.map",
    "NowClipboard.d.ts",
    "README.md",
    "README.en.md",
    "demo.html",
    "LICENSE"
  ],
  "keywords": [
    "clipboard",
    "copy",
    "cut",
    "paste",
    "image",
    "rich-text",
    "esm",
    "typescript",
    "剪贴板"
  ],
  "author": "Spicy-Mustard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Spicy-Mustard/NowClipboard.git"
  },
  "homepage": "https://github.com/Spicy-Mustard/NowClipboard",
  "bugs": {
    "url": "https://github.com/Spicy-Mustard/NowClipboard/issues"
  },
  "scripts": {
    "build": "node build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "vitest": "^4.1.7"
  }
}
