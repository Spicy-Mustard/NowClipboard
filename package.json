{
  "name": "nowclipboard",
  "version": "1.1.4",
  "description": "现代剪贴板工具库 - 零依赖，支持浏览器和 Node.js 双环境",
  "main": "dist/NowClipboard.js",
  "module": "dist/NowClipboard.esm.mjs",
  "types": "dist/NowClipboard.d.ts",
  "exports": {
    ".": {
      "types": "./dist/NowClipboard.d.ts",
      "import": "./dist/NowClipboard.esm.mjs",
      "require": "./dist/NowClipboard.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "README.en.md"
  ],
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=14"
  },
  "keywords": [
    "clipboard",
    "copy",
    "cut",
    "paste",
    "image",
    "rich-text",
    "esm",
    "typescript",
    "剪贴板"
  ],
  "author": "Spicy-Mustard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Spicy-Mustard/NowClipboard.git"
  },
  "homepage": "https://github.com/Spicy-Mustard/NowClipboard",
  "bugs": {
    "url": "https://github.com/Spicy-Mustard/NowClipboard/issues"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
